# EditorConfig: https://editorconfig.org/
# Keeps indentation + line endings consistent across editors.

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space

# Python — 4-space indent per PEP 8, max line length matches ruff (120).
[*.py]
indent_size = 4
max_line_length = 120

# YAML / TOML — 2-space indent (industry convention).
[*.{yml,yaml,toml}]
indent_size = 2

# Markdown — 2-space indent + DON'T trim trailing whitespace (it's
# significant for hard line breaks in Markdown).
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Makefiles need TAB indentation.
[Makefile]
indent_style = tab

# LaTeX — 2-space indent.
[*.tex]
indent_size = 2
